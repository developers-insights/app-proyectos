# Supabase — copiá este archivo a ".env" y completá con tus claves.
# Las encontrás en Supabase: Project Settings → API.
# (Si dejás estas variables vacías, la app funciona en modo LOCAL, guardando solo en este navegador.)

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-public-key

# Anthropic (chat IA / asistente). OPCIONAL: si la ponés acá, el chat funciona para
# todos sin cargarla en Ajustes. ATENCION: queda expuesta en el bundle publico del
# frontend, asi que ponele un limite de gasto a esa key en la consola de Anthropic.
VITE_ANTHROPIC_API_KEY=sk-ant-...
